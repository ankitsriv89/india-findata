# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored — never commit real credentials.

aws_region    = "ap-south-1"   # Mumbai — closest to Indian data sources
instance_type = "t3.small"     # minimum for ClickHouse (2 GB RAM)
key_name      = "my-keypair"   # name of an existing EC2 key pair

# Restrict SSH + UI access to your home IP for security:
# allowed_cidr = "203.0.113.42/32"

# For cheapest testing (spot, ~$5/month):
# use_spot = true
